# Frontend base URL (OAuth callbacks redirect back here)
FRONTEND_URL=http://localhost:5173

# Google / YouTube OAuth (social account connections)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:8000/api/social/callback/youtube

# Meta OAuth — ONE app covers both Facebook and Instagram
META_APP_ID=
META_APP_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:8000/api/social/callback/facebook
INSTAGRAM_OAUTH_REDIRECT_URI=http://localhost:8000/api/social/callback/instagram

# Publishing scopes are "Invalid Scopes" until added + approved in the Meta dashboard.
# Keep these False to connect with minimal scopes; set to true once approved.
FACEBOOK_PUBLISH_ENABLED=False
INSTAGRAM_PUBLISH_ENABLED=False

# Fernet key for encrypting stored social tokens (optional in dev; required in prod)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SOCIAL_TOKEN_ENCRYPTION_KEY=
